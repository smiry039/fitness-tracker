# Copy to `.env` for local dev, or set these in your host's environment.
# Nothing secret belongs in the repo — this file is only a template.

# --- Local development ---------------------------------------------------
# Local dev uses a SQLite file. Leave the Turso vars below unset locally.
DATABASE_URL="file:./dev.db"

# --- Production: Turso (libSQL) ------------------------------------------
# When TURSO_DATABASE_URL is set, the app talks to Turso instead of a file
# (see src/lib/db-client.ts). Get these from `turso db show` / `turso db tokens
# create` (or the Turso dashboard).
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# --- Protect a hosted instance ------------------------------------------
# If APP_PASSWORD is set, the whole site (pages + API) requires HTTP Basic
# Auth. Leave blank for local development (no prompt).
# Generate a strong one:  openssl rand -base64 24
APP_USER=""
APP_PASSWORD=""
